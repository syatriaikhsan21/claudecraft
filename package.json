{
  "name": "@wyverselabs/claudecraft",
  "version": "0.1.11",
  "description": "CLI for installing StarCraft sounds into Claude Code hooks",
  "type": "module",
  "packageManager": "bun@1.3.0",
  "bin": {
    "claudecraft": "./dist/cli.js"
  },
  "files": [
    "dist",
    "curated-sounds",
    "assets",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "curate:tool-sounds": "bun scripts/curate-tool-pools.ts --write",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "claude-code",
    "hooks",
    "starcraft",
    "cli"
  ],
  "author": "",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "@clack/prompts": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2"
  }
}
